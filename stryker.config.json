{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "pnpm",
  "testRunner": "jest",
  "jest": {
    "projectType": "custom",
    "configFile": "jest.stryker.config.ts"
  },
  "reporters": ["html", "clear-text", "progress"],
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/**/*.ts",
    "!src/**/*.spec.ts",
    "!src/**/index.ts"
  ],
  "thresholds": {
    "high": 99,
    "low": 95,
    "break": 95
  },
  "concurrency": 2
}
