{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": false,
    "verbatimModuleSyntax": false,
    "isolatedModules": false,
    "sourceMap": true,
    "inlineSourceMap": false,
    "types": ["node", "jest", "reflect-metadata"],
    "baseUrl": ".",
    "paths": {
      "@bymax-one/nest-queue": ["./src/server/index.ts"],
      "@bymax-one/nest-queue/shared": ["./src/shared/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "test/e2e/**/*.ts"],
  "exclude": ["node_modules", "dist", "coverage"]
}
